# Harmonia mobile — environment configuration
#
# The base URL of the Harmonia backend API. Must be EXPO_PUBLIC_* so Expo inlines
# it into the client bundle. Read in data/api.ts as process.env.EXPO_PUBLIC_API_URL.
#
# Expo picks the file by mode:
#   .env.development  → `expo start` (dev server / web)
#   .env.production   → `expo export` / EAS production builds
#   .env.local / .env.development.local → personal overrides (gitignored)
#
# No trailing slash needed (it is stripped in code anyway).
EXPO_PUBLIC_API_URL=https://harmonia-api-n8zp.onrender.com

# ── Physical-device note ────────────────────────────────────────────────────
# On a real phone (Expo Go), "localhost" is the phone itself, not your computer.
# To test against a local backend from a device, create .env.development.local
# with your machine's LAN IP, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
